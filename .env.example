# Server Configuration
PORT=7331

# Minimax API Key (required - fails startup if missing)
MINIMAX_API_KEY=your_key_here

# CORS Configuration
# Use '*' for all origins, or comma-separated list for multiple origins
# Use 'null' to disable CORS entirely
CORS_ORIGIN=*

# RATE_LIMIT_MAX: Maximum number of requests allowed per window per IP
#   - 100 is typically sufficient for normal API usage
RATE_LIMIT_MAX=100

# RATE_LIMIT_WINDOW_MS: Time window for rate limiting in milliseconds
#   - 900000ms = 15 minutes (default)
RATE_LIMIT_WINDOW_MS=900000

# Logflare Logging (logflare.app)
LOGFLARE_API_KEY=your_logflare_api_key
LOGFLARE_SOURCE_TOKEN=your_logflare_source_token